{
  "expo": {
    "name": "Мой ИТИ ХГУ",
    "slug": "mykhsu",
    "version": "2.3.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f3f4f6",
      "imageWidth": 60,
      "dark": {
        "image": "./assets/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#111827",
        "imageWidth": 60
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pro100byte.myitikhsu",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Приложению Мой ИТИ ХГУ требуется доступ к вашему местоположению для показа ближайших корпусов ХГУ на карте.",
        "NSLocationAlwaysUsageDescription": "Приложению Мой ИТИ ХГУ требуется доступ к вашему местоположению для показа ближайших корпусов ХГУ на карте.",
        "UIBackgroundModes": [
          "remote-notification",
          "fetch"
        ],
        "LSApplicationQueriesSchemes": [
          "yandexmaps",
          "yandexnavi",
          "comgooglemaps",
          "maps"
        ],
        "NSCalendarsFullAccessUsageDescription": "Приложению Мой ИТИ ХГУ требуется доступ к календарю для экспорта расписания занятий."
      },
      "backgroundColor": "#ffffff"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.pro100byte.myitikhsu",
      "versionCode": 1,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "ACCESS_WIFI_STATE",
        "FOREGROUND_SERVICE",
        "WAKE_LOCK",
        "READ_CALENDAR",
        "WRITE_CALENDAR",
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "$googleMapsApiKey"
        }
      },
      "allowBackup": true
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/", // temporary migrate from sentry.sculkmetrics.com to sentry.io, because of tech works on our server, after works we will migrate back
          "project": "mykhsu",
          "organization": "pro100byte-team" // temporary migrate from sculk to pro100byte-team, because of tech works on our server, after works we will migrate back
        }
      ],
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Разрешить приложению Мой ИТИ ХГУ использовать ваше местоположение для показа ближайших корпусов ХГУ на карте."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification.png",
          "color": "#ffffff",
          "sounds": [
            "./assets/notification.wav"
          ]
        }
      ],
      "expo-splash-screen",
      "expo-calendar"
    ],
    "extra": {
      "eas": {
        "projectId": "e1827dd8-4ea6-4b23-9f6a-5edc68c86d3d"
      },
      "dgApiKey": "$DG_API_KEY",
      "googleMapsApiKey": "$GOOGLE_MAPS_API_KEY"
    },
    "owner": "pro100byte",
    "sdkVersion": "54.0.0",
    "platforms": [
      "ios",
      "android"
    ]
  }
}
